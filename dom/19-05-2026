// countdown
 
function countdown(time){
    return new Promise((resolve) =>{
        setTimeout(() =>{
            resolve(time)
        },1000)

    })
}

async function start(){
    console.log(await countdown(3))
    console.log(await countdown(2))
    console.log(await countdown(1))
    console.log("go......")

}
start()