// promise.race(): the first come will win 
// retuns first completed promise
// can returnsuccess or failure


let pa=Promise.resolve("p1 done")
let pb=Promise.reject("p2 done")

Promise.race([pa,pb])

.then((pa)=>{
    console.log(pa)
})
.catch(()=>{
    console.log()
})

