// async and await

// async: it is used before a functionand it makes the function always return a promise

async function greet(){
    return"hello sana"
}
greet().then((result) =>{
    console.log(result)
})    

// await: used inside async function and it waits until the promise is completed

function testPromise(){
    return new Promise((resolve) =>{
        setTimeout(() =>{
            resolve("Data completed")
        },2000)
    })
}

async function getData(){
let result = await testPromise()
console.log(result)
}
getData()

