 // cleartimeout() // used to cancel a timeout set by setTimeout() before it execute
 
 let timer1 = setTimeout(() =>{
    console.log("hello")
 },1000)

 clearTimeout(timer1)

 // cancel notification
 let notification = setTimeout(()=>{
    console.log("NewMessage")
 },5000)
 console.log("Notification Cancelled")
 clearTimeout(notification)
 


