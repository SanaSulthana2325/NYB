    console.log("hello universe")
 }

 //
 let timer = setInterval(() =>{
    console.log("running...")
 },1000)

 setTimeout(() =>{
    clearInterval(timer)
 },2000)

 // counter stop
 let count = 0
 let interval = setInterval(()=>{
    count++
    console.log(count)

    if (count === 5){
        clearInterval(interval)
        console.log("Interval Stopped")
    }
 },1000)
