}
calculate()


// even or odd

function checkNumber(num){
    return new Promise((resolve) =>{
        setTimeout(() =>{
        if (num % 2 ===0){
            resolve("even number")
        }else{
            resolve("odd number")
        }
        },1000)
    })
}

async function result(){
    let data = await checkNumber(9)
    console.log(data)
}
result()

